# iptables rules for WireGuard forwarding and NAT
# Generated by Ansible - do not edit manually
*nat
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]
# Masquerade outbound traffic from wireguard clients going to ethernet
-A POSTROUTING -o {{ ethernet_iface }} -j MASQUERADE
COMMIT
*filter
:INPUT ACCEPT [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]
# Allow forwarding from wireguard to ethernet
-A FORWARD -i {{ wireguard_iface }} -o {{ ethernet_iface }} -j ACCEPT
# Allow established/related return traffic from ethernet back to wireguard
-A FORWARD -i {{ ethernet_iface }} -o {{ wireguard_iface }} -m state --state RELATED,ESTABLISHED -j ACCEPT
# Allow spoke to spoke communication
-A FORWARD -i {{ wireguard_iface }} -o {{ wireguard_iface }} -j ACCEPT
COMMIT
